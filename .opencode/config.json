{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "provider": {
    "cscs-inference": {
      "models": {
        "moonshotai/Kimi-K2.7-Code": {
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "name": "Kimi K2.7 Code"
        }
      },
      "name": "CSCS Inference",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CSCS_INFERENCE_API_KEY}",
        "baseURL": "{env:CSCS_INFERENCE_BASE_URL}"
      }
    }
  }
}
